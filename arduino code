#include <LiquidCrystal.h>

// LCD pin connections (RS, E, D4, D5, D6, D7)
LiquidCrystal lcd(7, 6, 5, 4, 3, 2);

// Sensor pins (use potentiometers in Tinkercad)
int mq7Pin = A0;   // CO sensor
int mq2Pin = A1;   // Smoke/Gas
int co2Pin = A2;   // CO2 (simulated)

// Buzzer pin
int buzzer = 8;

// Variables
int mq7Value = 0;
int mq2Value = 0;
int co2Value = 0;

String airQuality = "";

void setup() {
  lcd.begin(16, 2);
  pinMode(buzzer, OUTPUT);

  Serial.begin(9600);

  lcd.print("Air Quality");
  delay(2000);
  lcd.clear();
}

void loop() {

  // Read sensor values
  mq7Value = analogRead(mq7Pin);
  mq2Value = analogRead(mq2Pin);
  co2Value = analogRead(co2Pin);

  // Print to Serial Monitor
  Serial.print("MQ7: ");
  Serial.print(mq7Value);
  Serial.print(" | MQ2: ");
  Serial.print(mq2Value);
  Serial.print(" | CO2: ");
  Serial.println(co2Value);

  // Air Quality Logic
  if (mq7Value < 200 && mq2Value < 200 && co2Value < 200) {
    airQuality = "GOOD";
    digitalWrite(buzzer, LOW);
  }
  else if (mq7Value < 400 && mq2Value < 400) {
    airQuality = "MODERATE";
    digitalWrite(buzzer, LOW);
  }
  else if (mq7Value < 600 && mq2Value < 600) {
    airQuality = "POOR";
    digitalWrite(buzzer, HIGH);
  }
  else {
    airQuality = "DANGER!";
    digitalWrite(buzzer, HIGH);
  }

  // Display on LCD
  lcd.setCursor(0, 0);
  lcd.print("MQ7:");
  lcd.print(mq7Value);
  lcd.print(" ");

  lcd.setCursor(0, 1);
  lcd.print(airQuality);
  lcd.print("   ");

  delay(2000);
}
